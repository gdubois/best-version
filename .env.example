# =============================================================================
# Best Version - Environment Configuration
# =============================================================================
# Copy this file to .env and update with production values
# =============================================================================

# Application Configuration
NODE_ENV=production
PORT=3000

# Site Configuration (IMPORTANT: Update for production)
SITE_URL=https://www.best-version.com

# Email Configuration (Resend)
RESEND_API_KEY=your-resend-api-key

# =============================================================================
# SECURITY - Read SECURITY_SETUP.md before deploying to production
# =============================================================================

# Security (Generate secure values for production)
# Generate with: openssl rand -hex 32 or node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Must be at least 32 characters for security
COOKIE_SECRET=generate-new-secure-32-char-hex-string

# Admin Authentication (Generate secure password)
# IMPORTANT: Must be at least 16 characters with mixed case, numbers, and symbols
# Generate with: node -e "const c='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';console.log(Array(20).fill(0).map(()=>c[Math.random()*c.length]).join(''))"
ADMIN_PASSWORD=generate-new-secure-16-char-password

# Admin Settings
ADMIN_EMAIL=admin@best-version.com

# Newsletter Configuration
NEWSLETTER_EMAIL=newsletter@best-version.com

# Docker Volume Configuration
GAMES_DIR=games
SUBMISSIONS_DIR=submissions

# Story 6.6: Performance Optimization Configuration

# Cache Settings
CACHE_TTL=300                    # Cache TTL in seconds (5 minutes default)
CACHE_MAX=1000                   # Maximum cache entries
ENABLE_MEMORY_CACHE=true         # Enable in-memory caching
ENABLE_REDIS_CACHE=false         # Enable Redis caching

# Redis Settings (for distributed caching and sessions)
# Enable Redis for production deployments to persist sessions across restarts
REDIS_ENABLED=true               # Enable Redis for session storage (recommended for production)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                  # IMPORTANT: Set a secure password for production
REDIS_DB=0

# Image Optimization
IMAGE_QUALITY=80                 # Quality setting (1-100)
IMAGE_OUTPUT_FORMATS=webp,avif   # Output formats (comma-separated)

# Concurrency Settings
MAX_CONCURRENT_USERS=100         # Maximum concurrent user connections
RATE_LIMIT_REQUESTS=1000         # Rate limit requests per window
RATE_LIMIT_WINDOW=60000          # Rate limit window in milliseconds (60 seconds)
CONNECTION_TIMEOUT=300000        # Connection timeout in milliseconds (5 minutes)

# Static Asset Caching
STATIC_ASSET_CACHE=1 week        # Cache duration for static assets

# =============================================================================
# Game Creator Service Configuration
# =============================================================================
# Enables the automated game research and metadata creation service

# Game Creator Enable/Disable
GAME_CREATOR_ENABLED=true        # Enable the Game Creator service

# LLM Endpoint Configuration (remote llama.cpp server)
# Format options:
#   - Ollama: http://your-server-ip:11434/api/generate
#   - LM Studio: http://your-server-ip:1234/v1/chat/completions
#   - llama.cpp: http://your-server-ip:8080/v1/chat/completions
LLM_ENDPOINT=http://10.0.0.15:1234/v1/chat/completions

# LLM Model Name (e.g., llama3.2, mistral, codellama)
LLM_MODEL=llama3.2

# LLM Request Settings
LLM_TIMEOUT=120000               # Request timeout in milliseconds (120 seconds)
LLM_MAX_RETRIES=3                # Maximum retry attempts
LLM_TEMPERATURE=0.2              # Lower = more deterministic (good for JSON output)
LLM_MAX_TOKENS=8000              # Maximum tokens to generate

# MCP Server Configuration (Model Context Protocol)
MCP_SERVER_ENABLED=true          # Enable MCP server for web search tools
MCP_TIMEOUT=60000                # MCP server request timeout in milliseconds (60 seconds)

# DuckDuckGo Search Configuration
DUCKDUCKGO_ENABLED=true          # Enable DuckDuckGo search
DUCKDUCKGO_TIMEOUT=15000         # Request timeout in milliseconds (15 seconds)
DUCKDUCKGO_MAX_RETRIES=2         # Maximum retry attempts
DUCKDUCKGO_RATE_LIMIT_DELAY=60000 # Delay between requests in milliseconds (1 minute)
DUCKDUCKGO_MAX_RESULTS=10        # Maximum results to return

# Brave Search Configuration (uses Brave Search API)
# Get your API key from: https://brave.com/search/api/
BRAVE_SEARCH_ENABLED=true        # Enable Brave Search API
BRAVE_SEARCH_API_KEY=            # Your Brave Search API key
BRAVE_TIMEOUT=15000              # Request timeout in milliseconds
BRAVE_MAX_RETRIES=2              # Maximum retry attempts
BRAVE_RATE_LIMIT_DELAY=30000     # Delay between requests in milliseconds (30 seconds)
BRAVE_MAX_RESULTS=10             # Maximum results to return

# Open WebSearch Configuration (Brave Search API)
OPEN_WEBSEARCH_ENABLED=true      # Enable Open WebSearch via Brave Search API
OPEN_WEBSEARCH_API_KEY=          # Get your API key from https://brave.com/search/api/
OPEN_WEBSEARCH_API_URL=https://api.search.brave.com
OPEN_WEBSEARCH_TIMEOUT=15000     # Request timeout in milliseconds
OPEN_WEBSEARCH_MAX_RETRIES=2     # Maximum retry attempts
OPEN_WEBSEARCH_MAX_RESULTS=10    # Maximum results to return

# =============================================================================
# Open WebSearch MCP Package Configuration (Aas-ee/open-webSearch)
# =============================================================================
# Multi-engine web search without API keys (Bing, DuckDuckGo, Exa, Brave, etc.)
# The docker-compose setup includes this as a separate service

# Open WebSearch MCP Enable/Disable
OPEN_WEBSEARCH_MCP_ENABLED=true      # Enable the open-webSearch MCP package
OPEN_WEBSEARCH_MCP_ENGINE=duckduckgo # Default engine: duckduckgo, bing, exa, brave
OPEN_WEBSEARCH_MCP_HOST=http://open-websearch:3000  # Internal Docker host (for container)
# OPEN_WEBSEARCH_MCP_HOST=http://localhost:3001      # Localhost for local development
OPEN_WEBSEARCH_MCP_ENDPOINT=/search  # API endpoint path

# Proxy Configuration (for restricted regions like China)
USE_PROXY=false                      # Enable HTTP proxy for search requests
PROXY_URL=http://127.0.0.1:7890     # Proxy server URL
ALLOWED_SEARCH_ENGINES=duckduckgo,bing,exa,brave  # Comma-separated list of allowed engines
