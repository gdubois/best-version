# =============================================================================
# Best Version - Environment Configuration
# =============================================================================
# Copy this file to .env and update with production values
# =============================================================================

# Application Configuration
NODE_ENV=production
PORT=3000

# Site Configuration (IMPORTANT: Update for production)
SITE_URL=https://www.best-version.com

# Email Configuration (Resend)
RESEND_API_KEY=your-resend-api-key

# Security (Generate secure values for production)
# Generate with: openssl rand -base64 32
COOKIE_SECRET=change-this-to-a-random-secure-string-at-least-32-chars

# Admin Authentication (Generate secure password)
# Generate with: openssl rand -base64 32
ADMIN_PASSWORD=your-secure-admin-password

# Admin Settings
ADMIN_EMAIL=admin@best-version.com

# Newsletter Configuration
NEWSLETTER_EMAIL=newsletter@best-version.com

# Docker Volume Configuration
GAMES_DIR=games
SUBMISSIONS_DIR=submissions

# Story 6.6: Performance Optimization Configuration

# Cache Settings
CACHE_TTL=300                    # Cache TTL in seconds (5 minutes default)
CACHE_MAX=1000                   # Maximum cache entries
ENABLE_MEMORY_CACHE=true         # Enable in-memory caching
ENABLE_REDIS_CACHE=false         # Enable Redis caching

# Redis Settings (for distributed caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                  # Optional Redis password
REDIS_DB=0

# Image Optimization
IMAGE_QUALITY=80                 # Quality setting (1-100)
IMAGE_OUTPUT_FORMATS=webp,avif   # Output formats (comma-separated)

# Concurrency Settings
MAX_CONCURRENT_USERS=100         # Maximum concurrent user connections
RATE_LIMIT_REQUESTS=1000         # Rate limit requests per window
RATE_LIMIT_WINDOW=60000          # Rate limit window in milliseconds (60 seconds)
CONNECTION_TIMEOUT=300000        # Connection timeout in milliseconds (5 minutes)

# Static Asset Caching
STATIC_ASSET_CACHE=1 week        # Cache duration for static assets
