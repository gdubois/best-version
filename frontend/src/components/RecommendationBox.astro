---
/**
 * Recommendation Box Component - Updated to match index.html cyberpunk style
 */

interface Props {
  gameTitle?: string;
  platform: 'desktop-console' | 'handheld';
  emulator: string;
  version?: string;
  configNotes?: string;
  resourceLinks?: Array<{
    name: string;
    url: string;
    type: 'emulator' | 'rom' | 'patch' | 'documentation' | 'other';
  }>;
  hasUnofficialPatch?: boolean;
}

const {
  gameTitle,
  platform,
  emulator,
  version,
  configNotes,
  resourceLinks = [],
  hasUnofficialPatch = false,
} = Astro.props;

function renderResourceLinks(links: Props['resourceLinks']) {
  return links.map((link) => {
    let icon = '';
    let badgeClass = '';
    let label = link.type;

    switch (link.type) {
      case 'emulator':
        icon = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>';
        badgeClass = 'badge-info';
        break;
      case 'rom':
        icon = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><polyline points="13 2 13 9 20 9"></polyline></svg>';
        badgeClass = 'badge-info';
        break;
      case 'patch':
        icon = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>';
        badgeClass = 'badge-warning';
        break;
      case 'documentation':
        icon = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>';
        badgeClass = 'badge-info';
        break;
      default:
        icon = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>';
        badgeClass = 'badge-info';
    }

    return `
      <li>
        <a href="${link.url}" target="_blank" rel="noopener noreferrer" class="resource-link">
          <span class="resource-icon" aria-hidden="true">${icon}</span>
          <span class="resource-name">${link.name}</span>
          <span class="badge ${badgeClass}" aria-label="Link type: ${label}">${label}</span>
        </a>
      </li>
    `;
  }).join('');
}
---

<section class="recommendation-box" aria-labelledby="rec-heading-${gameTitle || 'default'}">
  <h2 id="rec-heading-${gameTitle || 'default'}" class="recommendation-box-header">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
    </svg>
    Best Way to Play
  </h2>

  <div class="recommendation-box-content">
    <!-- Platform indicator -->
    <div class="recommendation-platform-badge">
      ${platform === 'desktop-console'
        ? `<span class="badge badge-platform-desktop-console" aria-label="Desktop/Console platform">
             <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
               <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
               <line x1="8" y1="21" x2="16" y2="21"></line>
               <line x1="12" y1="17" x2="12" y2="21"></line>
             </svg>
             Desktop/Console
           </span>`
        : `<span class="badge badge-platform-handheld" aria-label="Handheld platform">
             <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
               <rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect>
               <line x1="12" y1="18" x2="12.01" y2="18"></line>
             </svg>
             Handheld
           </span>`}
    </div>

    <!-- Emulator info -->
    <div class="recommendation-emulator">
      <span class="emulator-name" aria-label="Recommended emulator">${emulator}</span>
      ${version
        ? `<span class="emulator-version">v${version}</span>`
        : ''}
    </div>

    <!-- Configuration notes -->
    ${configNotes
      ? `
      <div class="recommendation-config" aria-label="Configuration notes">
        <span class="config-label">Configuration:</span>
        <p>${configNotes}</p>
      </div>
      `
      : ''}

    <!-- Resource links -->
    ${resourceLinks.length > 0
      ? `
      <div class="recommendation-resources" aria-label="Resource links">
        <span class="resources-label">Resources:</span>
        <ul role="list">
          ${renderResourceLinks(resourceLinks)}
        </ul>
      </div>
      `
      : ''}

    <!-- Unofficial patch warning -->
    ${hasUnofficialPatch
      ? `
      <div class="recommendation-warning" role="alert" aria-label="Warning: unofficial patch">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
          <line x1="12" y1="9" x2="12" y2="13"></line>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
        <span>Unofficial patch available - use at your own risk</span>
      </div>
      `
      : ''}
  </div>
</section>

<style>
  /* Recommendation Box Component - Cyberpunk Style */

  .recommendation-box {
    background: var(--color-surface-primary);
    border-radius: var(--radius-2xl);
    padding: var(--space-5);
    border: 1px solid var(--color-border-default);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .recommendation-box-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    margin: 0 0 var(--space-4) 0;
  }

  .recommendation-box-header svg {
    color: var(--color-primary);
  }

  /* Platform badge */
  .recommendation-platform-badge {
    margin-bottom: var(--space-4);
  }

  /* Emulator info */
  .recommendation-emulator {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .emulator-name {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    font-family: var(--font-mono);
    color: var(--color-text-primary);
  }

  .emulator-version {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
  }

  /* Configuration notes */
  .recommendation-config {
    background: var(--color-surface-secondary);
    border-radius: var(--radius-lg);
    padding: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .config-label {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: var(--space-1);
  }

  .recommendation-config p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  /* Resource links */
  .recommendation-resources {
    margin-bottom: var(--space-4);
  }

  .resources-label {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: var(--space-2);
  }

  .recommendation-resources ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .resource-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .resource-link:hover {
    background: var(--color-surface-elevated);
    border-color: var(--color-primary);
    color: var(--color-text-primary);
  }

  .resource-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .resource-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .resource-name {
    font-weight: var(--font-medium);
  }

  /* Warning for unofficial patches */
  .recommendation-warning {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-3);
    background: rgba(255, 170, 0, 0.1);
    border: 1px solid rgba(255, 170, 0, 0.3);
    border-radius: var(--radius-lg);
    color: #ffaa00;
    font-size: var(--text-sm);
  }

  .recommendation-warning svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .recommendation-box {
      padding: var(--space-4);
    }

    .recommendation-box-header {
      font-size: var(--text-base);
    }

    .emulator-name {
      font-size: var(--text-lg);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .resource-link {
      transition: none;
    }

    .resource-link:hover {
      background-color: var(--color-surface-secondary);
    }
  }
</style>
