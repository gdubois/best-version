---
/**
 * Design Token Styles - Updated to match index.html cyberpunk/futuristic style
 *
 * This component injects CSS custom properties based on design tokens.
 * Ensures consistent theming across all pages.
 */

interface Props {
  dark?: boolean;
}

const { dark = true } = Astro.props;
---

<style is:global>
  /* CSS Custom Properties - Cyberpunk/Futuristic Design System */
  :root {
    /* Colors - Background */
    --color-bg-primary: #0a0a0f;
    --color-bg-secondary: #050507;
    --color-bg-tertiary: #1a1a2e;

    /* Colors - Surface */
    --color-surface-primary: #1a1a2e;
    --color-surface-secondary: rgba(26, 26, 46, 0.8);
    --color-surface-elevated: rgba(26, 26, 46, 0.95);

    /* Colors - Brand (from index.html) */
    --color-primary: #6366f1;
    --color-secondary: #8b5cf6;
    --color-accent: #ec4899;

    /* Colors - Text */
    --color-text-primary: #ffffff;
    --color-text-secondary: rgba(255, 255, 255, 0.8);
    --color-text-tertiary: rgba(255, 255, 255, 0.7);
    --color-text-muted: rgba(255, 255, 255, 0.5);

    /* Colors - Border */
    --color-border-default: rgba(99, 102, 241, 0.2);
    --color-border-light: rgba(99, 102, 241, 0.3);
    --color-border-dark: rgba(99, 102, 241, 0.2);

    /* Typography - Import fonts */
    --font-orbitron: 'Orbitron', sans-serif;
    --font-rajdhani: 'Rajdhani', sans-serif;

    /* Typography - Font Families */
    --font-sans: var(--font-rajdhani);
    --font-display: var(--font-orbitron);
    --font-mono: 'Fira Code', 'JetBrains Mono', 'Courier New', monospace;

    /* Typography - Font Sizes */
    --text-h1: clamp(2.5rem, 8vw, 6rem);
    --text-h2: clamp(2rem, 4vw, 3rem);
    --text-h3: clamp(1.8rem, 3vw, 2.5rem);
    --text-h4: clamp(1.5rem, 2vw, 2rem);
    --text-body: 1.1rem;
    --text-lg: 1.125rem;
    --text-base: 1rem;
    --text-sm: 0.9375rem;
    --text-xs: 0.85rem;

    /* Typography - Font Weights */
    --font-normal: 300;
    --font-medium: 500;
    --font-semibold: 700;
    --font-bold: 900;

    /* Typography - Line Heights */
    --leading-tight: 1.1;
    --leading-snug: 1.3;
    --leading-normal: 1.5;
    --leading-relaxed: 1.6;
    --leading-loose: 1.8;

    /* Spacing */
    --space-xs: 0.25rem;
    --space-sm: 0.5rem;
    --space-md: 1rem;
    --space-lg: 1.5rem;
    --space-xl: 2rem;
    --space-2xl: 3rem;
    --space-3xl: 4rem;
    --space-4xl: 6rem;
    --space-5xl: 8rem;

    /* Border Radius */
    --radius-none: 0;
    --radius-sm: 0.25rem;
    --radius-md: 0.5rem;
    --radius-lg: 0.75rem;
    --radius-xl: 1rem;
    --radius-2xl: 1.5rem;
    --radius-3xl: 2rem;
    --radius-full: 9999px;

    /* Box Shadows */
    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.3);
    --shadow-lg: 0 8px 25px rgba(0, 0, 0, 0.4);
    --shadow-xl: 0 20px 60px rgba(0, 0, 0, 0.5);
    --shadow-card: 0 4px 6px rgba(0, 0, 0, 0.3);
    --shadow-card-hover: 0 8px 25px rgba(99, 102, 241, 0.15);
    --shadow-glow-primary: 0 0 30px rgba(99, 102, 241, 0.4);
    --shadow-glow-accent: 0 0 30px rgba(236, 72, 153, 0.4);

    /* Transitions */
    --duration-fast: 150ms;
    --duration-normal: 300ms;
    --duration-slow: 500ms;
    --ease-default: cubic-bezier(0.4, 0, 0.2, 1);
    --ease-in: cubic-bezier(0.4, 0, 1, 1);
    --ease-out: cubic-bezier(0, 0, 0.2, 1);

    /* Z-Indices */
    --z-base: 0;
    --z-dropdown: 1000;
    --z-sticky: 1100;
    --z-fixed: 1200;
    --z-modal-backdrop: 1300;
    --z-modal: 1400;
    --z-toast: 1500;

    /* Component Tokens */
    --button-min-height: 2.75rem;
    --button-padding: 1rem 2rem;
    --input-min-height: 2.75rem;
    --input-padding: 1rem 1.5rem;
    --card-padding: 1.5rem;
    --badge-padding: 0.5rem 1rem;

    /* Gradients (from index.html) */
    --gradient-primary: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    --gradient-accent: linear-gradient(135deg, var(--color-secondary), var(--color-accent));
    --gradient-text: linear-gradient(135deg, var(--color-text-primary), var(--color-primary));
    --gradient-bg: linear-gradient(135deg, var(--color-bg-secondary) 0%, var(--color-bg-primary) 50%, var(--color-bg-tertiary) 100%);
    --gradient-nav: linear-gradient(135deg, rgba(26, 26, 46, 0.8), rgba(30, 30, 50, 0.9));

    /* Search Gradient */
    --gradient-search: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  }

  /* Dark theme (default) */
  :root {
    --color-bg-primary: #0a0a0f;
    --color-bg-secondary: #050507;
    --color-bg-tertiary: #1a1a2e;
    --color-surface-primary: #1a1a2e;
    --color-surface-secondary: rgba(26, 26, 46, 0.8);
    --color-surface-elevated: rgba(26, 26, 46, 0.95);
    --color-text-primary: #ffffff;
    --color-text-secondary: rgba(255, 255, 255, 0.8);
    --color-text-tertiary: rgba(255, 255, 255, 0.7);
    --color-text-muted: rgba(255, 255, 255, 0.5);
  }
</style>

<style>
  /* Base component styles using design tokens - Cyberpunk Style */

  /* Animated Background */
  .bg-animation {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background: var(--gradient-bg);
  }

  .bg-animation::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(99,102,241,0.1) 0%, transparent 50%),
                radial-gradient(circle, rgba(139,92,246,0.1) 0%, transparent 50%);
    animation: float 20s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(50px, -50px) rotate(120deg); }
    66% { transform: translate(-50px, 50px) rotate(240deg); }
  }

  /* Navigation */
  .cyber-nav {
    position: fixed;
    top: 0;
    width: 100%;
    padding: 1rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 1000;
    background: rgba(10, 10, 15, 0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border-default);
  }

  .cyber-logo {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: var(--font-bold);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 2px;
    text-decoration: none;
  }

  .cyber-nav-links {
    display: flex;
    gap: 3rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .cyber-nav-links a {
    color: var(--color-text-primary);
    text-decoration: none;
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    position: relative;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .cyber-nav-links a::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--gradient-search);
    transition: width var(--duration-normal) var(--ease-default);
  }

  .cyber-nav-links a:hover::after {
    width: 100%;
  }

  /* Typography utilities */
  .text-h1 { font-family: var(--font-display); font-size: var(--text-h1); line-height: var(--leading-tight); font-weight: var(--font-bold); }
  .text-h2 { font-family: var(--font-display); font-size: var(--text-h2); line-height: var(--leading-tight); font-weight: var(--font-bold); }
  .text-h3 { font-family: var(--font-display); font-size: var(--text-h3); line-height: var(--leading-snug); font-weight: var(--font-semibold); }
  .text-h4 { font-family: var(--font-display); font-size: var(--text-h4); line-height: var(--leading-snug); font-weight: var(--font-semibold); }
  .text-body { font-family: var(--font-sans); font-size: var(--text-body); line-height: var(--leading-relaxed); font-weight: var(--font-normal); }
  .text-sm { font-family: var(--font-sans); font-size: var(--text-sm); line-height: var(--leading-normal); font-weight: var(--font-normal); }
  .text-xs { font-family: var(--font-sans); font-size: var(--text-xs); line-height: var(--leading-normal); font-weight: var(--font-normal); }

  /* Text colors */
  .text-primary { color: var(--color-text-primary); }
  .text-secondary { color: var(--color-text-secondary); }
  .text-tertiary { color: var(--color-text-tertiary); }
  .text-muted { color: var(--color-text-muted); }
  .text-accent { color: var(--color-accent); }

  /* Gradient text utility */
  .text-gradient {
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .text-gradient-primary {
    background: linear-gradient(135deg, var(--color-text-primary), var(--color-primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--button-min-height);
    padding: var(--button-padding);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    text-decoration: none;
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-default);
    border: none;
    gap: 0.5rem;
    border-radius: var(--radius-full);
  }

  .btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-primary {
    background: var(--gradient-primary);
    color: var(--color-text-primary);
    box-shadow: 0 10px 40px rgba(99, 102, 241, 0.4);
  }

  .btn-primary:hover:not(:disabled) {
    transform: translateY(-3px);
    box-shadow: 0 15px 50px rgba(99, 102, 241, 0.6);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 2px solid var(--color-primary);
  }

  .btn-secondary:hover:not(:disabled) {
    background: rgba(99, 102, 241, 0.1);
    transform: translateY(-3px);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-text-primary);
    border: 2px solid var(--color-border-default);
  }

  .btn-outline:hover:not(:disabled) {
    border-color: var(--color-primary);
    background: rgba(99, 102, 241, 0.1);
  }

  /* Inputs */
  .input,
  textarea,
  select {
    min-height: var(--input-min-height);
    padding: var(--input-padding);
    border-radius: var(--radius-full);
    font-size: var(--text-base);
    background: var(--color-surface-secondary);
    border: 2px solid var(--color-border-default);
    color: var(--color-text-primary);
    transition: all var(--duration-normal) var(--ease-default);
    backdrop-filter: blur(10px);
  }

  .input:focus,
  textarea:focus,
  select:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1),
                0 0 30px rgba(99, 102, 241, 0.4),
                inset 0 1px 1px rgba(255, 255, 255, 0.1);
  }

  .input::placeholder {
    color: var(--color-text-muted);
  }

  /* Cards */
  .card {
    background: var(--color-surface-primary);
    border-radius: var(--radius-2xl);
    padding: var(--card-padding);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    border: 1px solid var(--color-border-default);
  }

  .card:hover {
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  /* Badges */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: var(--badge-padding);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
  }

  .badge-platform-desktop-console {
    background: rgba(99, 102, 241, 0.15);
    color: var(--color-primary);
    border: 1px solid rgba(99, 102, 241, 0.3);
  }

  .badge-platform-handheld {
    background: rgba(139, 92, 246, 0.15);
    color: var(--color-secondary);
    border: 1px solid rgba(139, 92, 246, 0.3);
  }

  .badge-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-text-secondary);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .badge-info {
    background: rgba(58, 134, 255, 0.15);
    color: var(--color-primary);
    border: 1px solid rgba(58, 134, 255, 0.3);
  }

  .badge-warning {
    background: rgba(255, 170, 0, 0.15);
    color: #ffaa00;
    border: 1px solid rgba(255, 170, 0, 0.3);
  }

  /* Search Bar */
  .search-bar {
    width: 100%;
    max-width: 320px;
  }

  .search-container {
    display: flex;
    align-items: center;
    position: relative;
  }

  .search-input {
    width: 100%;
    padding: 0.9rem 3.5rem 0.9rem 1.8rem;
    border: 2px solid rgba(99, 102, 241, 0.3);
    border-radius: var(--radius-full);
    background: var(--gradient-nav);
    color: var(--color-text-primary);
    font-size: var(--text-base);
    outline: none;
    transition: all var(--duration-normal) cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(10px);
  }

  .search-input:focus {
    width: 360px;
    border-color: transparent;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.15), rgba(139, 92, 246, 0.15));
    box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1),
                0 0 30px rgba(99, 102, 241, 0.4);
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-submit {
    position: absolute;
    right: 12px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .search-submit:hover svg {
    transform: scale(1.1);
    filter: drop-shadow(0 0 8px rgba(99, 102, 241, 0.6));
  }

  .search-submit svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: url(#searchGradient);
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: all var(--duration-normal) var(--ease-default);
  }

  /* Game Cards */
  .game-card {
    background: var(--color-surface-primary);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: all var(--duration-normal) var(--ease-default);
    border: 1px solid var(--color-border-dark);
    display: flex;
    flex-direction: column;
  }

  .game-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 255, 136, 0.15);
    border-color: #00ff88;
  }

  .game-card-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .game-card-cover {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: linear-gradient(135deg, #1a1a1a, #222222);
  }

  .game-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .game-card:hover .game-card-image {
    transform: scale(1.05);
  }

  .game-card-content {
    padding: var(--space-4);
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .game-card-title {
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3) 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .game-card-badges {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    align-items: center;
  }

  /* Hero Section */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 2rem 4rem;
  }

  /* Section Styles */
  .section {
    padding: 6rem 3rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    text-align: center;
    margin-bottom: 3rem;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Stats Grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background: var(--color-surface-secondary);
    padding: 2rem;
    border-radius: var(--radius-2xl);
    text-align: center;
    border: 1px solid var(--color-border-default);
    transition: all var(--duration-normal) var(--ease-default);
  }

  .stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(99, 102, 241, 0.2);
    border-color: rgba(99, 102, 241, 0.4);
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: var(--font-bold);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    color: var(--color-text-tertiary);
    font-size: var(--text-sm);
  }

  /* Back Link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-primary);
    text-decoration: none;
    font-weight: var(--font-medium);
    margin-bottom: 2rem;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .back-link:hover svg {
    transform: translateX(-3px);
  }

  .back-link svg {
    transition: transform var(--duration-normal) var(--ease-default);
  }

  /* Container */
  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  /* Form styles */
  .form-label {
    display: block;
    color: var(--color-text-primary);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    margin-bottom: var(--space-2);
  }

  .form-hint {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }

  .form-error {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-accent);
    margin-top: var(--space-1);
  }

  .required-indicator {
    color: var(--color-accent);
    font-weight: var(--font-bold);
  }

  /* Footer */
  footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border-default);
    text-align: center;
    color: var(--color-text-muted);
  }

  /* Accessibility - Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }

    .btn:hover,
    .card:hover,
    .game-card:hover {
      transform: none;
    }

    .game-card-image {
      transform: none;
    }
  }
</style>
