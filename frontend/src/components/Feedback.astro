---
/**
 * Feedback Component - Story 7.16: Feedback Patterns
 *
 * Displays toast notifications with success, error, warning, or info messages.
 * Auto-dismisses after 3 seconds. Accessible with ARIA live regions.
 *
 * @prop {'success' | 'error' | 'warning' | 'info'} type - Feedback type
 * @prop {string} message - Feedback message to display
 * @prop {boolean} visible - Whether the feedback is shown
 * @prop {(type: 'success' | 'error' | 'warning' | 'info') => void} onClose - Callback when dismissed
 */

interface Props {
  type: 'success' | 'error' | 'warning' | 'info';
  message: string;
  visible?: boolean;
  onClose?: (type: 'success' | 'error' | 'warning' | 'info') => void;
}

const { type = 'info', message = '', visible = true, onClose } = Astro.props;

// Icon mapping for feedback types
function getIcon() {
  switch (type) {
    case 'success':
      return `<svg class="feedback-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
        <polyline points="22 4 12 14.01 9 11.01"></polyline>
      </svg>`;
    case 'error':
      return `<svg class="feedback-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="15" y1="9" x2="9" y2="15"></line>
        <line x1="9" y1="9" x2="15" y2="15"></line>
      </svg>`;
    case 'warning':
      return `<svg class="feedback-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
        <line x1="12" y1="9" x2="12" y2="13"></line>
        <line x1="12" y1="17" x2="12.01" y2="17"></line>
      </svg>`;
    case 'info':
    default:
      return `<svg class="feedback-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="16" x2="12" y2="12"></line>
        <line x1="12" y1="8" x2="12.01" y2="8"></line>
      </svg>`;
  }
}

function handleClose() {
  if (onClose) {
    onClose(type);
  }
}

const iconHTML = getIcon();
const className = `feedback toast feedback-${type}`;
---

<div
  class={className}
  role="alert"
  aria-live="polite"
  aria-atomic="true"
  hidden={!visible}
  on:click={!onClose ? undefined : handleClose}
>
  {@html iconHTML}
  <p class="feedback-message">{message}</p>
  <button
    class="feedback-close"
    on:click={handleClose}
    aria-label="Dismiss notification"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
</div>

<style>
  /* Feedback Component - Story 7.16: Feedback Patterns */

  .feedback {
    position: fixed;
    bottom: var(--space-4);
    right: var(--space-4);
    padding: var(--space-4) var(--space-6);
    border-radius: var(--radius-lg);
    background-color: var(--color-surface-primary);
    border: 1px solid var(--color-border-default);
    box-shadow: var(--shadow-lg);
    z-index: var(--z-toast);
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    animation: toast-slide-in var(--duration-normal) var(--ease-out);
    max-width: 400px;
    cursor: pointer;
  }

  @keyframes toast-slide-in {
    from {
      transform: translateY(100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .feedback-icon {
    flex-shrink: 0;
  }

  .feedback-message {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
    margin: 0;
    line-height: var(--line-height-normal);
    flex: 1;
  }

  .feedback-close {
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: var(--space-1);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    transition: color var(--duration-fast) var(--ease-default);
  }

  .feedback-close:hover {
    color: var(--color-text-primary);
    background-color: var(--color-surface-secondary);
  }

  /* Feedback type variants */
  .feedback-success {
    border-left: 4px solid var(--color-success);
  }

  .feedback-success .feedback-icon {
    color: var(--color-success);
  }

  .feedback-error {
    border-left: 4px solid var(--color-error);
  }

  .feedback-error .feedback-icon {
    color: var(--color-error);
  }

  .feedback-warning {
    border-left: 4px solid var(--color-warning);
  }

  .feedback-warning .feedback-icon {
    color: var(--color-warning);
  }

  .feedback-info {
    border-left: 4px solid var(--color-info);
  }

  .feedback-info .feedback-icon {
    color: var(--color-info);
  }

  /* Responsive adjustments */
  @media (max-width: 767px) {
    .feedback {
      left: var(--space-4);
      right: var(--space-4);
      bottom: var(--space-2);
      max-width: none;
    }
  }

  /* Reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    .feedback {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script client>
  /**
   * Feedback Component Client Script - Story 7.16: Feedback Patterns
   *
   * Handles auto-dismiss after 3 seconds.
   */

  const feedbackElement = Astro.self.element;
  if (!feedbackElement) {
    console.warn('Feedback element not found');
  } else {
    let dismissTimeout: number | null = null;

    function startAutoDismiss() {
      if (dismissTimeout) {
        window.clearTimeout(dismissTimeout);
      }

      dismissTimeout = window.setTimeout(() => {
        const closeBtn = feedbackElement.querySelector('.feedback-close');
        if (closeBtn) {
          closeBtn.click();
        }
      }, 3000);
    }

    function cancelAutoDismiss() {
      if (dismissTimeout) {
        window.clearTimeout(dismissTimeout);
        dismissTimeout = null;
      }
    }

    // Start auto-dismiss when visible
    if (Astro.props.visible) {
      startAutoDismiss();
    }

    // Listen for visibility changes
    const observer = new MutationObserver((mutations) => {
      for (const mutation of mutations) {
        if (mutation.attributeName === 'hidden') {
          if (feedbackElement.hidden) {
            cancelAutoDismiss();
          } else {
            startAutoDismiss();
          }
        }
      }
    });

    observer.observe(feedbackElement, { attributes: true });

    // Cleanup on disconnect
    feedbackElement.addEventListener('astro:disconnect', () => {
      observer.disconnect();
      if (dismissTimeout) {
        window.clearTimeout(dismissTimeout);
      }
    });
  }
</script>
