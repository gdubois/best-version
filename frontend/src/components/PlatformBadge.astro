---
/**
 * Platform Badge Component - Updated to match index.html cyberpunk style
 */

interface Props {
  type: 'desktop-console' | 'handheld';
  label?: string;
  large?: boolean;
}

const { type = 'desktop-console', label, large = false } = Astro.props;
const sizeClass = large ? 'badge-lg' : 'badge';
---

<span
  class={`badge badge-platform-${type} ${sizeClass}`}
  role="listitem"
  aria-label={label || `${type} platform`}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="${large ? '16' : '14'}"
    height="${large ? '16' : '14'}"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    ${type === 'desktop-console'
      ? `
        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
        <line x1="8" y1="21" x2="16" y2="21"></line>
        <line x1="12" y1="17" x2="12" y2="21"></line>
      `
      : `
        <rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect>
        <line x1="12" y1="18" x2="12.01" y2="18"></line>
      `
    }
  </svg>
  ${type === 'desktop-console' ? 'Desktop/Console' : 'Handheld'}
</span>

<style>
  /* Platform Badge Component - Cyberpunk Style */

  .badge-lg {
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-base);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .badge-platform-desktop-console {
    background: rgba(99, 102, 241, 0.15);
    color: var(--color-primary);
    border: 1px solid rgba(99, 102, 241, 0.3);
  }

  .badge-platform-handheld {
    background: rgba(139, 92, 246, 0.15);
    color: var(--color-secondary);
    border: 1px solid rgba(139, 92, 246, 0.3);
  }
</style>
