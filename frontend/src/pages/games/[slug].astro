---
import Layout from '../../layouts/Layout.astro';
import GameCard from '../../components/GameCard.astro';
import PlatformTabs from '../../components/PlatformTabs.astro';
import RecommendationBox from '../../components/RecommendationBox.astro';
import EmptyState from '../../components/EmptyState.astro';

export async function getStaticPaths() {
  const globResults = import.meta.glob<{ default: any }>( '../../../../games/*.json' );
  const paths = Object.keys(globResults).map((filePath) => {
    const slug = filePath.split('/').pop()?.replace('.json', '') || '';
    return { params: { slug } };
  });

  return paths;
}

export function generateMeta({ slug }) {
  const game = getGameBySlug(slug);
  return {
    title: game ? `${game.basic_info?.title} - Best Version` : 'Game Not Found - Best Version',
    description: game?.description?.synopsis || 'Find the best way to play your favorite retro games.',
  };
}

function getGameBySlug(slug) {
  try {
    const files = import.meta.glob('../../../games/*.json', { eager: true });
    const filePath = `/games/${slug}.json`;
    if (files[filePath]) {
      return files[filePath].default;
    }
    return null;
  } catch {
    return null;
  }
}

const { slug } = Astro.props;
const game = getGameBySlug(slug);

// Pre-compute platform data for PlatformTabs
const desktopPlatforms = game?.play_today
  ? game.play_today
    .filter(entry => entry.platform.toLowerCase().includes('handheld') === false)
    .map(entry => {
      const patchesData = (entry.recommended_patches || []).filter(Boolean).map(p => ({
        name: p.name,
        description: p.description,
        url: p.url
      }));
      return {
        platform: entry.platform,
        emulator: entry.recommended_emulator || 'N/A',
        version: entry.emulator_version || '',
        configLink: entry.config_link || '',
        patches: patchesData
      };
    })
  : [];

const handheldPlatforms = game?.play_today
  ? game.play_today
    .filter(entry => entry.platform.toLowerCase().includes('handheld'))
    .map(entry => {
      const patchesData = (entry.recommended_patches || []).filter(Boolean).map(p => ({
        name: p.name,
        description: p.description,
        url: p.url
      }));
      return {
        platform: entry.platform,
        emulator: entry.recommended_emulator || 'N/A',
        version: entry.emulator_version || '',
        configLink: entry.config_link || '',
        patches: patchesData
      };
    })
  : [];

// Prepare platform section content
const platformSection = (() => {
  if (!game?.play_today || game.play_today?.length === 0) {
    return {
      type: 'empty',
      message: 'No platform recommendations available for this game yet.'
    };
  }
  return {
    type: 'tabs',
    desktopPlatforms,
    handheldPlatforms
  };
})();

// Prepare similar games section
const similarGamesSection = (() => {
  if (!game?.similar_games || game.similar_games?.length === 0) {
    return null;
  }
  return game.similar_games.slice(0, 6);
})();

---

<Layout title={game ? `${game.basic_info?.title} - Best Version` : 'Game Not Found - Best Version'}>
  <main id="main-content" role="main" style="padding-top: 100px;">
    {game ? (
      <article aria-labelledby="game-title" style="max-width: 900px; margin: 0 auto;">
        <!-- Back Button -->
        <div style="margin-bottom: 2rem;">
          <a href="/" class="back-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to Home
          </a>
        </div>

        <!-- Game Header -->
        <section class="game-header py-8" aria-labelledby="game-title">
          <div class="max-w-6xl mx-auto px-4">
            <h1 id="game-title" class="text-h2 mb-4 text-gradient-primary">{game.basic_info?.title || game.title}</h1>

            <!-- Alternative Names -->
            {game.basic_info?.alternative_names?.length > 0 && (
              <div class="mb-6">
                <p class="text-secondary">
                  Also known as:{' '}
                  <span style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                    {game.basic_info.alternative_names.map((name, index) => (
                      <span key={index} class="badge badge-secondary">{name}</span>
                    ))}
                  </span>
                </p>
              </div>
            )}

            <!-- Cover Image -->
            {game.basic_info?.cover_image && (
              <div class="mb-6">
                <img
                  src={game.basic_info.cover_image}
                  alt={`${game.basic_info.title || 'Game cover'} cover art`}
                  class="game-cover-image"
                />
              </div>
            )}
          </div>
        </section>

        <!-- Description -->
        {game.description?.synopsis && (
          <section class="mb-8" aria-labelledby="description-heading">
            <div class="max-w-4xl mx-auto px-4">
              <h2 id="description-heading" class="text-h3 mb-4 text-gradient-primary">About</h2>
              <p class="text-body text-secondary leading-relaxed" style="font-size: 1.1rem; line-height: 1.8;">{game.description.synopsis}</p>
            </div>
          </section>
        )}

        <!-- Best Way to Play with Platform Tabs -->
        {platformSection.type === 'empty' ? (
          <section class="mb-8" aria-labelledby="platform-heading">
            <div class="max-w-4xl mx-auto px-4">
              <h2 id="platform-heading" class="text-h3 mb-4 text-gradient-primary">Best Way to Play</h2>
              <EmptyState message={platformSection.message} />
            </div>
          </section>
        ) : (
          <section class="mb-8" aria-labelledby="platform-heading">
            <div class="max-w-4xl mx-auto px-4">
              <h2 id="platform-heading" class="text-h3 mb-6 text-gradient-primary">Best Way to Play</h2>

              <PlatformTabs>
                {(() => {
                  if (platformSection.desktopPlatforms.length === 0 && platformSection.handheldPlatforms.length === 0) {
                    return null;
                  }
                  return (
                    <>
                      {platformSection.desktopPlatforms.map(data => (
                        <div slot="desktop-console" class="mb-4" key={data.platform}>
                          <h3 class="text-lg font-semibold mb-3" style="font-family: 'Orbitron', sans-serif; color: var(--color-primary);">{data.platform}</h3>
                          <RecommendationBox platform="desktop-console" emulator={data.emulator} version={data.version} configNotes={data.configLink} hasUnofficialPatch={data.patches.length > 0} />
                        </div>
                      ))}
                      {platformSection.handheldPlatforms.map(data => (
                        <div slot="handheld" class="mb-4" key={data.platform}>
                          <h3 class="text-lg font-semibold mb-3" style="font-family: 'Orbitron', sans-serif; color: var(--color-primary);">{data.platform}</h3>
                          <RecommendationBox platform="handheld" emulator={data.emulator} version={data.version} configNotes={data.configLink} hasUnofficialPatch={data.patches.length > 0} />
                        </div>
                      ))}
                    </>
                  );
                })()}
              </PlatformTabs>
            </div>
          </section>
        )}

        <!-- Similar Games -->
        {similarGamesSection && (
          <section class="mb-8" aria-labelledby="similar-heading">
            <div class="max-w-6xl mx-auto px-4">
              <h2 id="similar-heading" class="text-h3 mb-6 text-gradient-primary">Similar Games</h2>
              <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
                {similarGamesSection.map((simGame) => (
                  <GameCard
                    title={simGame.title || simGame.basic_info?.title}
                    slug={simGame.url_slug || simGame.basic_info?.url_slug}
                    platforms={['desktop-console']}
                  />
                ))}
              </div>
            </div>
          </section>
        )}

        <section class="mb-8" style="padding-top: 2rem;">
          <a href="/" class="btn btn-outline">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to Home
          </a>
        </section>
      </article>
    ) : (
      <EmptyState
        message="Game not found"
        searchQuery=""
        actionUrl="/"
        actionText="Return Home"
      />
    )}
  </main>
</Layout>

<script is:inline>
  function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
</script>

<style>
  .game-cover-image {
    max-height: 400px;
    width: 100%;
    object-fit: cover;
    border-radius: 1rem;
  }
</style>
