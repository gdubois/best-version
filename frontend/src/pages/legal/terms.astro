---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Terms of Service - Best Version">
  <main id="main-content" role="main" style="padding-top: 100px; max-width: 900px; margin: 0 auto;">
    <section class="py-8">
      <a href="/" class="back-link" style="margin-bottom: 2rem;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to Home
      </a>

      <div class="card" style="padding: 2rem;">
        <h1 class="text-h2 mb-6 text-gradient-primary">Terms of Service</h1>

        <div class="prose max-w-none">
          <p class="text-secondary mb-6">Last updated: April 2024</p>

          <h2 class="text-h3 mb-4">Agreement to Terms</h2>
          <p>
            By accessing and using Best Version, you agree to be bound by these Terms of Service.
            If you do not agree to these terms, please do not use this website.
          </p>

          <h2 class="text-h3 mb-4">Description of Service</h2>
          <p>
            Best Version is a community-driven website dedicated to documenting the best versions
            of classic games for various platforms and emulators. Our service includes:
          </p>
          <ul>
            <li>Game information and documentation</li>
            <li>Emulator recommendations and configurations</li>
            <li>User-submitted game recommendations</li>
          </ul>

          <h2 class="text-h3 mb-4">User Submissions</h2>
          <p>
            By submitting content to Best Version, you represent and warrant that:
          </p>
          <ul>
            <li>You have the right to submit the content</li>
            <li>The content does not violate any applicable laws</li>
            <li>The content is accurate and not misleading</li>
          </ul>
          <p>
            You grant Best Version a non-exclusive, royalty-free license to use, display, and
            distribute your submissions on our website.
          </p>

          <h2 class="text-h3 mb-4">Intellectual Property</h2>
          <p>
            All content on Best Version, including text, graphics, logos, and artwork, is the
            property of Best Version or its content providers and is protected by copyright laws.
          </p>

          <h2 class="text-h3 mb-4">Acceptable Use</h2>
          <p>
            You agree not to:
          </p>
          <ul>
            <li>Use the website for any illegal purpose</li>
            <li>Attempt to gain unauthorized access to our systems</li>
            <li>Interfere with the proper working of the website</li>
            <li>Submit false or misleading information</li>
            <li>Use automated systems to access the website without permission</li>
          </ul>

          <h2 class="text-h3 mb-4">Disclaimer of Warranties</h2>
          <p>
            The website is provided on an "as is" and "as available" basis without any warranties
            of any kind, either express or implied. We do not warrant that the information
            provided is accurate, complete, or current.
          </p>

          <h2 class="text-h3 mb-4">Limitation of Liability</h2>
          <p>
            Best Version and its operators shall not be liable for any damages arising from your
            use of the website, including but not limited to direct, indirect, incidental, or
            consequential damages.
          </p>

          <h2 class="text-h3 mb-4">Third-Party Links</h2>
          <p>
            Our website may contain links to third-party websites. We have no control over and
            assume no responsibility for the content, privacy policies, or practices of any
            third-party sites.
          </p>

          <h2 class="text-h3 mb-4">Modifications to Terms</h2>
          <p>
            We reserve the right to modify these terms at any time. Continued use of the website
            after changes constitutes acceptance of the new terms.
          </p>

          <h2 class="text-h3 mb-4">Governing Law</h2>
          <p>
            These terms shall be governed by and construed in accordance with applicable laws,
            without regard to its conflict of law principles.
          </p>

          <h2 class="text-h3 mb-4">Contact Information</h2>
          <p>
            If you have questions about these Terms of Service, please contact us at:
            <br />
            Email: legal@bestversion.example.com
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .prose {
    line-height: 1.8;
  }

  .prose h2 {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #6366f1;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #ffffff;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .prose p {
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 1rem;
  }

  .prose ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose li {
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 0.5rem;
  }
</style>
