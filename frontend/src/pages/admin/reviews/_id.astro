---
import Layout from '../../layouts/Layout.astro';

const reviewId = Astro.params.id;

// Fetch review details from API
interface ReviewDetail {
    id: string;
    title: string;
    submittedAt: string;
    needsReviewAt: string;
    confidenceScore: number;
    issues: Array<{ field: string; severity: string; message: string }>;
    draftData: any;
}

let review: ReviewDetail | null = null;
let error: string | null = null;

try {
    const response = await fetch(`http://localhost:1234/api/admin/pending-reviews/${reviewId}`, {
        headers: {
            'Authorization': `Bearer ${Astro.locals.adminToken || ''}`
        }
    });

    if (response.ok) {
        review = await response.json();
    } else {
        error = 'Failed to load review details';
    }
} catch (e) {
    error = 'Unable to connect to review service';
}
---

<Layout title={review ? `Review: ${review.title} - Admin` : 'Review - Admin'}>
    <main id="main-content" role="main" class="review-detail-page">
        <section class="py-8">
            <div class="max-w-5xl mx-auto px-4">
                <!-- Header -->
                <div class="mb-6">
                    <nav class="breadcrumb mb-4" aria-label="Breadcrumb">
                        <a href="/admin/reviews" class="breadcrumb-link">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <line x1="19" y1="12" x2="5" y2="12"></line>
                                <polyline points="12 19 5 12 12 5"></polyline>
                            </svg>
                            Review Queue
                        </a>
                        <span class="breadcrumb-separator">/</span>
                        <span class="breadcrumb-current">{review?.title || 'Loading...'}</span>
                    </nav>

                    {review && (
                        <div class="review-header">
                            <h1 class="text-h3">{review.title}</h1>
                            <div class="header-meta">
                                <span class={`confidence-badge confidence-${review.confidenceScore >= 0.7 ? 'good' : review.confidenceScore >= 0.5 ? 'medium' : 'low'}`}>
                                    <span class="confidence-value">{Math.round(review.confidenceScore * 100)}%</span>
                                    <span class="confidence-label">confidence</span>
                                </span>
                            </div>
                        </div>
                    )}
                </div>

                <!-- Error State -->
                {error && (
                    <div role="alert" class="alert alert-error">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                        <span>{error}</span>
                    </div>
                )}

                {review && !error && (
                    <div class="review-content">
                        <!-- Issues Section -->
                        {review.issues.length > 0 && (
                            <div class="issues-section" role="alert" aria-labelledby="issues-heading">
                                <h2 id="issues-heading" class="section-title">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path>
                                        <line x1="12" y1="9" x2="12" y2="13"></line>
                                        <line x1="12" y1="17" x2="12.01" y2="17"></line>
                                    </svg>
                                    Validation Issues ({review.issues.length})
                                </h2>
                                <div class="issues-grid">
                                    {review.issues.map((issue, index) => (
                                        <div class={`issue-card issue-${issue.severity}`} role="alert">
                                            <div class="issue-header">
                                                <span class="issue-severity-badge">{issue.severity.toUpperCase()}</span>
                                                <span class="issue-field-name">{issue.field}</span>
                                            </div>
                                            <p class="issue-description">{issue.message}</p>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        )}

                        <!-- Draft Data Section -->
                        {review.draftData ? (
                            <div class="data-section">
                                <h2 class="section-title">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                        <polyline points="14 2 14 8 20 8"></polyline>
                                    </svg>
                                    Generated Data
                                </h2>
                                <div class="data-preview">
                                    <div class="data-tabs">
                                        <button class="tab-btn active" data-tab="basic" onclick="switchTab('basic')">Basic Info</button>
                                        <button class="tab-btn" data-tab="release" onclick="switchTab('release')">Release Info</button>
                                        <button class="tab-btn" data-tab="description" onclick="switchTab('description')">Description</button>
                                        <button class="tab-btn" data-tab="raw" onclick="switchTab('raw')">Raw JSON</button>
                                    </div>

                                    <div class="tab-content" id="tab-basic">
                                        <div class="data-grid">
                                            <div class="data-field">
                                                <label>Title</label>
                                                <p>{review.draftData.basic_info?.title || 'N/A'}</p>
                                            </div>
                                            <div class="data-field">
                                                <label>URL Slug</label>
                                                <p>{review.draftData.basic_info?.url_slug || 'N/A'}</p>
                                            </div>
                                            <div class="data-field">
                                                <label>Genres</label>
                                                <p>{Array.isArray(review.draftData.basic_info?.genres) ? review.draftData.basic_info.genres.join(', ') : 'N/A'}</p>
                                            </div>
                                            <div class="data-field">
                                                <label>Developers</label>
                                                <p>{Array.isArray(review.draftData.basic_info?.developers) ? review.draftData.basic_info.developers.join(', ') : 'N/A'}</p>
                                            </div>
                                            <div class="data-field">
                                                <label>Publishers</label>
                                                <p>{Array.isArray(review.draftData.basic_info?.publishers) ? review.draftData.basic_info.publishers.join(', ') : 'N/A'}</p>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="tab-content hidden" id="tab-release">
                                        <div class="data-grid">
                                            <div class="data-field">
                                                <label>Platforms</label>
                                                <p>{Array.isArray(review.draftData.release_info?.platforms) ? review.draftData.release_info.platforms.join(', ') : 'N/A'}</p>
                                            </div>
                                            <div class="data-field">
                                                <label>Release Date</label>
                                                <p>{review.draftData.release_info?.release_date || 'N/A'}</p>
                                            </div>
                                            <div class="data-field">
                                                <label>Regions</label>
                                                <p>{Array.isArray(review.draftData.release_info?.regions) ? review.draftData.release_info.regions.join(', ') : 'N/A'}</p>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="tab-content hidden" id="tab-description">
                                        <div class="data-field full-width">
                                            <label>Synopsis</label>
                                            <p>{review.draftData.description?.synopsis || 'N/A'}</p>
                                        </div>
                                        <div class="data-field full-width mt-4">
                                            <label>Key Features</label>
                                            <ul>{Array.isArray(review.draftData.description?.key_features) ? review.draftData.description.key_features.map(f => <li>{f}</li>) : '<li>N/A</li>'}</ul>
                                        </div>
                                        <div class="data-field full-width mt-4">
                                            <label>Long Description</label>
                                            <p class="long-description">{review.draftData.description?.long_description || 'N/A'}</p>
                                        </div>
                                    </div>

                                    <div class="tab-content hidden" id="tab-raw">
                                        <pre class="json-preview"><code>{JSON.stringify(review.draftData, null, 2)}</code></pre>
                                    </div>
                                </div>
                            </div>
                        ) : (
                            <div class="no-data-alert">
                                <p>No draft data available for this submission.</p>
                            </div>
                        )}

                        <!-- Action Buttons -->
                        <div class="action-section">
                            <h2 class="section-title">Actions</h2>
                            <form id="approve-form" class="action-form" onsubmit="handleSubmit(event, 'approve')">
                                <input type="hidden" id="game-data-input" name="gameData" value="" />
                                <button type="submit" class="btn btn-success btn-lg">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                    Approve & Save
                                </button>
                            </form>

                            <form id="reject-form" class="action-form" onsubmit="handleSubmit(event, 'reject')">
                                <div class="reject-reason" id="reject-reason-container" style="display: none;">
                                    <label for="reject-reason-input">Reason for rejection (optional)</label>
                                    <textarea id="reject-reason-input" name="reason" rows="3" placeholder="Add a reason for rejection..."></textarea>
                                </div>
                                <button type="button" class="btn btn-danger btn-lg" onclick="showRejectReason()">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <line x1="18" y1="6" x2="6" y2="18"></line>
                                        <line x1="6" y1="6" x2="18" y2="18"></line>
                                    </svg>
                                    Reject
                                </button>
                                <button type="submit" class="btn btn-danger btn-lg" style="display: none;" id="reject-submit">
                                    Confirm Rejection
                                </button>
                            </form>

                            <div class="action-links">
                                <a href="/admin/reviews" class="btn btn-outline">
                                    Back to Queue
                                </a>
                            </div>
                        </div>
                    </div>
                )}
            </div>
        </section>
    </main>
</Layout>

<script>
    function switchTab(tabId) {
        // Hide all tab contents
        document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
        // Remove active from all buttons
        document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));

        // Show selected tab
        document.getElementById('tab-' + tabId).classList.remove('hidden');
        // Activate button
        event.target.classList.add('active');
    }

    function showRejectReason() {
        document.getElementById('reject-reason-container').style.display = 'block';
        event.target.style.display = 'none';
        document.getElementById('reject-submit').style.display = 'inline-flex';
    }

    async function handleSubmit(event, action) {
        event.preventDefault();

        const formData = new FormData(event.target);
        const data = {
            gameData: action === 'approve' ? JSON.parse(document.getElementById('game-data-input').value || '{}') : null,
            reason: action === 'reject' ? document.getElementById('reject-reason-input').value : null
        };

        try {
            const response = await fetch(`http://localhost:1234/api/admin/pending-reviews/${ Astro.params.id }/${action}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer localStorage.getItem('adminToken') || ''`
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (result.success) {
                alert(result.message || `Submission ${action}d successfully`);
                window.location.href = '/admin/reviews';
            } else {
                alert('Error: ' + (result.error || 'Failed to ' + action + ' submission'));
            }
        } catch (error) {
            alert('Error: ' + error.message);
        }
    }

    // Set the game data for approve form
    const reviewData = { /* would be populated from review.draftData */ };
</script>

<style>
    .review-detail-page {
        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        min-height: 100vh;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
    }

    .breadcrumb-link {
        color: #2563eb;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    .breadcrumb-separator {
        color: #9ca3af;
    }

    .breadcrumb-current {
        color: #6b7280;
    }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
    }

    .confidence-badge {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0.75rem 1rem;
        border-radius: 8px;
    }

    .confidence-badge.confidence-good { background: #d1fae5; color: #065f46; }
    .confidence-badge.confidence-medium { background: #fef3c7; color: #92400e; }
    .confidence-badge.confidence-low { background: #fee2e2; color: #991b1b; }

    .issues-section, .data-section, .action-section {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0 0 1rem 0;
        font-size: 1.125rem;
        font-weight: 600;
        color: #1f2937;
    }

    .issues-grid {
        display: grid;
        gap: 0.75rem;
    }

    .issue-card {
        padding: 1rem;
        border-radius: 8px;
        border-left: 4px solid;
    }

    .issue-card.issue-critical { background: #fef2f2; border-color: #dc2626; }
    .issue-card.issue-high { background: #fff7ed; border-color: #ea580c; }
    .issue-card.issue-medium { background: #fffbeb; border-color: #ca8a04; }
    .issue-card.issue-low { background: #fefce8; border-color: #eab308; }

    .issue-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .issue-severity-badge {
        font-size: 0.625rem;
        font-weight: 700;
        padding: 0.125rem 0.375rem;
        border-radius: 4px;
        background: rgba(0, 0, 0, 0.1);
    }

    .issue-field-name {
        font-weight: 600;
    }

    .issue-description {
        margin: 0;
        font-size: 0.875rem;
        color: #4b5563;
    }

    .data-tabs {
        display: flex;
        gap: 0.25rem;
        border-bottom: 1px solid #e5e7eb;
        margin-bottom: 1rem;
    }

    .tab-btn {
        padding: 0.75rem 1rem;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 0.875rem;
        color: #6b7280;
        border-bottom: 2px solid transparent;
        transition: color 0.2s, border-color 0.2s;
    }

    .tab-btn.active {
        color: #2563eb;
        border-bottom-color: #2563eb;
    }

    .tab-content.hidden { display: none; }

    .data-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
    }

    .data-field label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.25rem;
    }

    .data-field p {
        margin: 0;
        color: #1f2937;
        font-size: 0.9375rem;
    }

    .data-field.full-width { grid-column: 1 / -1; }

    .long-description {
        line-height: 1.7;
        white-space: pre-wrap;
    }

    .json-preview {
        background: #1f2937;
        color: #e5e7eb;
        padding: 1rem;
        border-radius: 8px;
        overflow-x: auto;
        font-size: 0.8125rem;
        line-height: 1.5;
    }

    .action-form {
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
        flex-wrap: wrap;
    }

    .reject-reason {
        flex: 1;
        min-width: 200px;
    }

    .reject-reason label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.875rem;
        color: #374151;
    }

    .reject-reason textarea {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-family: inherit;
    }

    .action-links {
        margin-top: 1rem;
    }

    .btn-lg {
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-success {
        background: #10b981;
        color: white;
        border: none;
    }

    .btn-danger {
        background: #ef4444;
        color: white;
        border: none;
    }

    @media (max-width: 640px) {
        .review-header { flex-direction: column; }
        .action-form { flex-direction: column; }
    }
</style>
