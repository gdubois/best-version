---
import Layout from '../../layouts/Layout.astro';

interface ReviewItem {
    id: string;
    title: string;
    submittedAt: string;
    needsReviewAt: string;
    confidenceScore: number;
    issues: Array<{ field: string; severity: string; message: string }>;
    draftPath: string | null;
}

// API base URL - use relative URL in production
const API_BASE = import.meta.env.VITE_API_BASE_URL || '/api';

// Fetch pending reviews from API
let reviews: ReviewItem[] = [];
let error: string | null = null;

try {
    const response = await fetch(`${API_BASE}/admin/pending-reviews`, {
        headers: {
            'Authorization': `Bearer ${Astro.locals.adminToken || ''}`
        }
    });

    if (response.ok) {
        const data = await response.json();
        reviews = data.submissions || [];
    } else {
        error = 'Failed to load pending reviews';
    }
} catch (e) {
    error = 'Unable to connect to review service';
}

// Sort by needsReviewAt descending (most recent first)
reviews.sort((a, b) => new Date(b.needsReviewAt).getTime() - new Date(a.needsReviewAt).getTime());
---

<Layout title="Review Queue - Admin - Best Version">
    <main id="main-content" role="main" class="reviews-page">
        <section class="py-8">
            <div class="max-w-7xl mx-auto px-4">
                <!-- Header -->
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
                    <div>
                        <h1 class="text-h2">Review Queue</h1>
                        <p class="text-gray-600 mt-2">Review and approve generated game metadata</p>
                    </div>
                    <a href="/admin/dashboard" class="btn btn-outline inline-flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <line x1="19" y1="12" x2="5" y2="12"></line>
                            <polyline points="12 19 5 12 12 5"></polyline>
                        </svg>
                        Back to Dashboard
                    </a>
                </div>

                <!-- Error State -->
                {error && (
                    <div role="alert" class="alert alert-error mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                        <span>{error}</span>
                    </div>
                )}

                <!-- Empty State -->
                {reviews.length === 0 && !error && (
                    <div role="status" class="empty-state">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                        <h2 class="text-h4 mt-4 mb-2">No Pending Reviews</h2>
                        <p class="text-gray-600">All caught up! Check back later for new submissions needing review.</p>
                        <button class="btn btn-primary mt-6" onclick="location.reload()">Refresh Queue</button>
                    </div>
                )}

                <!-- Reviews List -->
                {reviews.length > 0 && !error && (
                    <div class="space-y-4" role="list" aria-label="Pending reviews">
                        {reviews.map((review) => (
                            <article class="review-card" role="listitem">
                                <div class="review-header">
                                    <div class="review-title">
                                        <h3 class="text-h5">{review.title}</h3>
                                        <div class="review-meta">
                                            <span class="meta-item" title="Submitted at">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                                    <circle cx="12" cy="12" r="10"></circle>
                                                    <polyline points="12 6 12 12 16 14"></polyline>
                                                </svg>
                                                {new Date(review.submittedAt).toLocaleDateString()}
                                            </span>
                                            <span class="meta-item" title="Needs review since">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                                    <circle cx="12" cy="12" r="10"></circle>
                                                    <line x1="12" y1="16" x2="12" y2="12"></line>
                                                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                                                </svg>
                                                Needs review since {new Date(review.needsReviewAt).toLocaleDateString()}
                                            </span>
                                        </div>
                                    </div>

                                    <div class="review-score">
                                        <div class={`confidence-badge confidence-${review.confidenceScore >= 0.7 ? 'good' : review.confidenceScore >= 0.5 ? 'medium' : 'low'}`}>
                                            <span class="confidence-value">{Math.round(review.confidenceScore * 100)}%</span>
                                            <span class="confidence-label">confidence</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Issues Summary -->
                                {review.issues.length > 0 && (
                                    <div class="review-issues" role="alert" aria-label={`${review.issues.length} issues found`}>
                                        <div class="issues-header">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                                <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path>
                                                <line x1="12" y1="9" x2="12" y2="13"></line>
                                                <line x1="12" y1="17" x2="12.01" y2="17"></line>
                                            </svg>
                                            <span>{review.issues.length} issue{review.issues.length > 1 ? 's' : ''} found</span>
                                        </div>
                                        <ul class="issues-list">
                                            {review.issues.slice(0, 3).map((issue) => (
                                                <li class={`issue-item issue-${issue.severity}`}>
                                                    <span class="issue-severity">{issue.severity.toUpperCase()}</span>
                                                    <span class="issue-field">{issue.field}</span>
                                                    <span class="issue-message">{issue.message}</span>
                                                </li>
                                            ))}
                                            {review.issues.length > 3 && (
                                                <li class="issue-more">
                                                    <a href={`/admin/reviews/${review.id}`} aria-label={`View all ${review.issues.length} issues for ${review.title}`}>
                                                        +{review.issues.length - 3} more issues
                                                    </a>
                                                </li>
                                            )}
                                        </ul>
                                    </div>
                                )}

                                <!-- Actions -->
                                <div class="review-actions">
                                    <a href={`/admin/reviews/${review.id}`} class="btn btn-primary" aria-label={`Review ${review.title}`}>
                                        Review & Edit
                                    </a>
                                    <a href={`/admin/reviews/${review.id}?view=preview`} class="btn btn-outline" aria-label={`Preview ${review.title}`}>
                                        Preview
                                    </a>
                                </div>
                            </article>
                        ))}
                    </div>
                )}

                <!-- Summary Footer -->
                {reviews.length > 0 && !error && (
                    <footer class="review-summary mt-8">
                        <p>Showing <strong>{reviews.length}</strong> pending review{reviews.length > 1 ? 's' : ''}</p>
                        <button class="btn btn-sm btn-outline" onclick="location.reload()">Refresh</button>
                    </footer>
                )}
            </div>
        </section>
    </main>
</Layout>

<style>
    .reviews-page {
        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        min-height: 100vh;
    }

    .review-card {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .review-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .review-title {
        flex: 1;
        min-width: 0;
    }

    .review-title h3 {
        margin: 0 0 0.5rem 0;
        font-size: 1.25rem;
        font-weight: 600;
        color: #1f2937;
        word-break: break-word;
    }

    .review-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .meta-item {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.875rem;
        color: #6b7280;
    }

    .confidence-badge {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        text-align: center;
    }

    .confidence-badge.confidence-good {
        background: #d1fae5;
        color: #065f46;
    }

    .confidence-badge.confidence-medium {
        background: #fef3c7;
        color: #92400e;
    }

    .confidence-badge.confidence-low {
        background: #fee2e2;
        color: #991b1b;
    }

    .confidence-value {
        font-size: 1.25rem;
        font-weight: 700;
    }

    .confidence-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .review-issues {
        background: #fef3c7;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .issues-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #92400e;
        font-weight: 600;
        margin-bottom: 0.75rem;
    }

    .issues-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .issue-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid rgba(146, 64, 14, 0.1);
    }

    .issue-item:last-child {
        border-bottom: none;
    }

    .issue-item.issue-critical {
        color: #991b1b;
    }

    .issue-item.issue-high {
        color: #c2410c;
    }

    .issue-item.issue-medium {
        color: #a16207;
    }

    .issue-item.issue-low {
        color: #ca8a04;
    }

    .issue-severity {
        font-size: 0.625rem;
        font-weight: 700;
        padding: 0.125rem 0.375rem;
        border-radius: 4px;
        background: rgba(0, 0, 0, 0.1);
    }

    .issue-field {
        font-weight: 500;
    }

    .issue-message {
        font-size: 0.875rem;
        color: #4b5563;
    }

    .issue-more {
        padding: 0.5rem 0;
    }

    .issue-more a {
        color: #2563eb;
        text-decoration: underline;
        font-size: 0.875rem;
    }

    .review-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .review-summary {
        background: white;
        border-radius: 8px;
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .empty-state svg {
        color: #d1d5db;
    }

    /* Responsive adjustments */
    @media (max-width: 640px) {
        .review-header {
            flex-direction: column;
        }

        .review-actions {
            flex-direction: column;
        }

        .review-actions .btn {
            width: 100%;
        }
    }
</style>
