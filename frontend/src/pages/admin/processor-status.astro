---
import Layout from '../../layouts/Layout.astro';

// API base URL - use relative URL in production
const API_BASE = import.meta.env.VITE_API_BASE_URL || '/api';

// Fetch processor status from API
let processorStatus: any = null;
let error: string | null = null;

try {
    const response = await fetch(`${API_BASE}/admin/processor-status`, {
        headers: {
            'Authorization': `Bearer ${Astro.locals.adminToken || ''}`
        }
    });

    if (response.ok) {
        processorStatus = await response.json();
    } else {
        error = 'Failed to load processor status';
    }
} catch (e) {
    error = 'Unable to connect to processor service';
}
---

<Layout title="Processor Status - Admin - Best Version">
    <main id="main-content" role="main" class="processor-status-page">
        <section class="py-8">
            <div class="max-w-6xl mx-auto px-4">
                <!-- Header -->
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
                    <div>
                        <h1 class="text-h2">Processor Status</h1>
                        <p class="text-gray-600 mt-2">Monitor and control the automated game creator</p>
                    </div>
                    <a href="/admin/dashboard" class="btn btn-outline inline-flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <line x1="19" y1="12" x2="5" y2="12"></line>
                            <polyline points="12 19 5 12 12 5"></polyline>
                        </svg>
                        Back to Dashboard
                    </a>
                </div>

                <!-- Error State -->
                {error && (
                    <div role="alert" class="alert alert-error mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                        <span>{error}</span>
                    </div>
                )}

                {processorStatus && !error && (
                    <>
                        <!-- Status Banner -->
                        <div class={`status-banner ${processorStatus.status === 'running' ? 'status-running' : processorStatus.status === 'stopped' ? 'status-stopped' : 'status-idle'}`}>
                            <div class="status-icon">
                                {processorStatus.status === 'running' && (
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <path d="M12 2v20M2 12h20"></path>
                                    </svg>
                                )}
                                {processorStatus.status === 'idle' && (
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <circle cx="12" cy="12" r="10"></circle>
                                        <polyline points="12 6 12 12 16 14"></polyline>
                                    </svg>
                                )}
                                {processorStatus.status === 'stopped' && (
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                        <line x1="9" y1="9" x2="15" y2="15"></line>
                                        <line x1="15" y1="9" x2="9" y2="15"></line>
                                    </svg>
                                )}
                            </div>
                            <div class="status-text">
                                <span class="status-label">Status:</span>
                                <span class="status-value">{processorStatus.status === 'running' ? 'Processing' : processorStatus.status === 'idle' ? 'Idle' : 'Stopped'}</span>
                            </div>
                        </div>

                        <!-- Stats Grid -->
                        <div class="stats-grid">
                            <div class="stat-card">
                                <div class="stat-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect>
                                        <line x1="9" y1="9" x2="15" y2="15"></line>
                                        <line x1="15" y1="9" x2="9" y2="15"></line>
                                    </svg>
                                </div>
                                <div class="stat-value">{processorStatus.queue?.pending || 0}</div>
                                <div class="stat-label">Pending</div>
                            </div>

                            <div class="stat-card stat-card-processed">
                                <div class="stat-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                </div>
                                <div class="stat-value">{processorStatus.processing?.today?.processed || 0}</div>
                                <div class="stat-label">Processed Today</div>
                            </div>

                            <div class="stat-card stat-card-failed">
                                <div class="stat-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"></circle>
                                        <line x1="15" y1="9" x2="9" y2="15"></line>
                                        <line x1="9" y1="9" x2="15" y2="15"></line>
                                    </svg>
                                </div>
                                <div class="stat-value">{processorStatus.processing?.today?.failed || 0}</div>
                                <div class="stat-label">Failed Today</div>
                            </div>

                            <div class="stat-card stat-card-review">
                                <div class="stat-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                        <polyline points="14 2 14 8 20 8"></polyline>
                                        <line x1="16" y1="13" x2="8" y2="13"></line>
                                        <line x1="16" y1="17" x2="8" y2="17"></line>
                                    </svg>
                                </div>
                                <div class="stat-value">{processorStatus.processing?.today?.needsReview || 0}</div>
                                <div class="stat-label">Needs Review</div>
                            </div>
                        </div>

                        <!-- Scheduler Info -->
                        <div class="scheduler-card">
                            <h2 class="section-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <polyline points="12 6 12 12 16 14"></polyline>
                                </svg>
                                Scheduler
                            </h2>
                            <div class="scheduler-info">
                                <div class="scheduler-item">
                                    <span class="scheduler-label">Last Run:</span>
                                    <span class="scheduler-value">{processorStatus.scheduler?.lastRun ? new Date(processorStatus.scheduler.lastRun).toLocaleString() : 'Never'}</span>
                                </div>
                                <div class="scheduler-item">
                                    <span class="scheduler-label">Next Run:</span>
                                    <span class="scheduler-value">{processorStatus.scheduler?.nextRun ? new Date(processorStatus.scheduler.nextRun).toLocaleString() : 'N/A'}</span>
                                </div>
                                <div class="scheduler-item">
                                    <span class="scheduler-label">Schedule:</span>
                                    <span class="scheduler-value">{processorStatus.scheduler?.schedule || 'Hourly at :30'}</span>
                                </div>
                                <div class="scheduler-item">
                                    <span class="scheduler-label">Enabled:</span>
                                    <span class={`scheduler-value ${processorStatus.scheduler?.enabled ? 'text-success' : 'text-error'}`}>
                                        {processorStatus.scheduler?.enabled ? 'Yes' : 'No'}
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Currently Processing -->
                        {processorStatus.currentlyProcessing && (
                            <div class="processing-card">
                                <h2 class="section-title">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <polyline points="23 4 23 10 17 10"></polyline>
                                        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
                                    </svg>
                                    Currently Processing
                                </h2>
                                <div class="processing-item">
                                    <div class="processing-title">{processorStatus.currentlyProcessing.title}</div>
                                    <div class="processing-meta">
                                        <span>Started: {new Date(processorStatus.currentlyProcessing.startedAt).toLocaleTimeString()}</span>
                                    </div>
                                </div>
                            </div>
                        )}

                        <!-- Manual Actions -->
                        <div class="actions-card">
                            <h2 class="section-title">Manual Actions</h2>
                            <div class="actions-grid">
                                <button id="run-now-btn" class="btn btn-primary btn-lg" onclick="runNow()">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <polygon points="5 3 19 12 5 21 5 3"></polygon>
                                    </svg>
                                    Run Now
                                </button>
                                <a href="/admin/reviews" class="btn btn-outline btn-lg">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                        <polyline points="14 2 14 8 20 8"></polyline>
                                    </svg>
                                    Review Queue
                                </a>
                                <a href="/admin/failed" class="btn btn-outline btn-lg">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <circle cx="12" cy="12" r="10"></circle>
                                        <line x1="15" y1="9" x2="9" y2="15"></line>
                                        <line x1="9" y1="9" x2="15" y2="15"></line>
                                    </svg>
                                    Failed Submissions
                                </a>
                            </div>
                        </div>
                    </>
                )}

                <!-- Auto-refresh notice -->
                {processorStatus && !error && (
                    <footer class="refresh-notice">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <polyline points="23 4 23 10 17 10"></polyline>
                            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
                        </svg>
                        <span>Auto-refreshes every 30 seconds</span>
                    </footer>
                )}
            </div>
        </section>
    </main>
</Layout>

<script>
    async function runNow() {
        const btn = document.getElementById('run-now-btn');
        btn.disabled = true;
        btn.textContent = 'Running...';

        try {
            const response = await fetch('http://localhost:1234/api/admin/processor-status/run', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${localStorage.getItem('adminToken') || ''}`
                }
            });

            if (response.ok) {
                alert('Processor started!');
                location.reload();
            } else {
                alert('Failed to run processor');
                btn.disabled = false;
                btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>Run Now';
            }
        } catch (error) {
            alert('Error: ' + error.message);
            btn.disabled = false;
            btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>Run Now';
        }
    }

    // Auto-refresh every 30 seconds
    setInterval(() => {
        location.reload();
    }, 30000);
</script>

<style>
    .processor-status-page {
        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        min-height: 100vh;
    }

    .status-banner {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
    }

    .status-banner.status-running {
        background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
        color: #065f46;
    }

    .status-banner.status-idle {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        color: #92400e;
    }

    .status-banner.status-stopped {
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        color: #991b1b;
    }

    .status-icon {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .status-text {
        display: flex;
        flex-direction: column;
    }

    .status-label {
        font-size: 0.875rem;
        opacity: 0.8;
    }

    .status-value {
        font-size: 1.5rem;
        font-weight: 700;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6b7280;
    }

    .stat-card-processed .stat-icon { background: #d1fae5; color: #059669; }
    .stat-card-failed .stat-icon { background: #fee2e2; color: #dc2626; }
    .stat-card-review .stat-icon { background: #fef3c7; color: #d97706; }

    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: #1f2937;
    }

    .stat-label {
        font-size: 0.875rem;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .scheduler-card, .processing-card, .actions-card {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0 0 1rem 0;
        font-size: 1.125rem;
        font-weight: 600;
        color: #1f2937;
    }

    .scheduler-info {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .scheduler-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 0;
        border-bottom: 1px solid #f3f4f6;
    }

    .scheduler-item:last-child {
        border-bottom: none;
    }

    .scheduler-label {
        color: #6b7280;
        font-size: 0.9375rem;
    }

    .scheduler-value {
        color: #1f2937;
        font-weight: 500;
        font-size: 0.9375rem;
    }

    .text-success { color: #10b981; }
    .text-error { color: #ef4444; }

    .processing-item {
        background: #f8fafc;
        border-radius: 8px;
        padding: 1rem;
    }

    .processing-title {
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 0.25rem;
    }

    .processing-meta {
        font-size: 0.875rem;
        color: #6b7280;
    }

    .actions-grid {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .btn-lg {
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .refresh-notice {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 1rem;
        color: #6b7280;
        font-size: 0.875rem;
    }

    @media (max-width: 640px) {
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
        .actions-grid { flex-direction: column; }
    }
</style>
